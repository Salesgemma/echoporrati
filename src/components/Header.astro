---
// src/components/Header.astro
const currentPath = Astro.url.pathname;
const isItalian = currentPath.startsWith('/it');

// Detect current language from path
type Lang = 'en' | 'it' | 'es' | 'de' | 'ar';
const supportedLangs: Lang[] = ['en', 'it', 'es', 'de', 'ar'];
const detectedLang = currentPath.split('/')[1] || 'en';
const currentLang: Lang = (supportedLangs as string[]).includes(detectedLang) ? detectedLang as Lang : 'en';

// Route segment maps per language
const routeMap: Record<Lang, Record<string, string>> = {
    en: { collections: 'collections', products: 'products', showroom: 'showroom-milan', code: 'jewel-code', faq: 'faq', archive: 'borgonuovo10-archive', knowledge: 'knowledge' },
    it: { collections: 'collezioni', products: 'prodotti', showroom: 'showroom-milano', code: 'codice-gioiello', faq: 'faq', archive: 'borgonuovo10-archive', knowledge: 'enciclopedia' },
    es: { collections: 'colecciones', products: 'productos', showroom: 'showroom-milan', code: 'codigo-joya', faq: 'faq', archive: 'borgonuovo10-archive', knowledge: 'enciclopedia' },
    de: { collections: 'kollektionen', products: 'produkte', showroom: 'showroom-mailand', code: 'schmuck-code', faq: 'faq', archive: 'borgonuovo10-archive', knowledge: 'enzyklopaedie' },
    ar: { collections: 'collections', products: 'products', showroom: 'showroom-milan', code: 'jewel-code', faq: 'faq', archive: 'borgonuovo10-archive', knowledge: 'knowledge' },
};

const collectionSlugs: Record<Lang, Record<string, string>> = {
    en: { pendants: 'pendants', rings: 'rings', bracelets: 'bracelets', earrings: 'earrings' },
    it: { pendants: 'pendenti', rings: 'anelli', bracelets: 'bracciali', earrings: 'orecchini' },
    es: { pendants: 'colgantes', rings: 'anillos', bracelets: 'pulseras', earrings: 'pendientes' },
    de: { pendants: 'anhaenger', rings: 'ringe', bracelets: 'armbaender', earrings: 'ohrringe' },
    ar: { pendants: 'pendants', rings: 'rings', bracelets: 'bracelets', earrings: 'earrings' },
};

// Reverse lookup: find canonical key from any localized slug
function findCanonicalSlug(slug: string, type: 'collection' | 'route'): string {
    const maps = type === 'collection' ? collectionSlugs : routeMap;
    for (const lang of supportedLangs) {
        for (const [canonical, localized] of Object.entries(maps[lang])) {
            if (localized === slug) return canonical;
        }
    }
    return slug;
}

function getLanguagePath(targetLang: Lang): string {
    if (currentPath === '/' || supportedLangs.some(l => currentPath === `/${l}`)) {
        return `/${targetLang}`;
    }
    
    const parts = currentPath.split('/').filter(Boolean); // e.g. ['en', 'collections', 'rings']
    const sourceLang = parts[0] as Lang;
    const segments = parts.slice(1); // e.g. ['collections', 'rings']
    
    if (!segments.length) return `/${targetLang}`;
    
    // Find canonical route key for the first segment
    const canonicalRoute = findCanonicalSlug(segments[0], 'route');
    const targetRoute = routeMap[targetLang][canonicalRoute] || segments[0];
    
    // Handle collection sub-slugs
    if ((canonicalRoute === 'collections') && segments[1]) {
        const canonicalCollection = findCanonicalSlug(segments[1], 'collection');
        const targetCollection = collectionSlugs[targetLang][canonicalCollection] || segments[1];
        return `/${targetLang}/${targetRoute}/${targetCollection}`;
    }
    
    // Handle product sub-slugs (product IDs are universal)
    if (canonicalRoute === 'products' && segments[1]) {
        return `/${targetLang}/${targetRoute}/${segments.slice(1).join('/')}`;
    }
    
    return `/${targetLang}/${targetRoute}${segments.length > 1 ? '/' + segments.slice(1).join('/') : ''}`;
}

// Nav labels per language
const navLabels: Record<Lang, Record<string, string>> = {
    en: { collections: 'COLLECTIONS', showroom: 'SHOWROOM', code: 'CODE', archive: 'ARCHIVE', home: 'Home', faq: 'FAQ', jewelCode: 'Jewel Code' },
    it: { collections: 'COLLEZIONI', showroom: 'SHOWROOM', code: 'CODICE', archive: 'ARCHIVE', home: 'Home', faq: 'FAQ', jewelCode: 'Codice Gioiello' },
    es: { collections: 'COLECCIONES', showroom: 'SHOWROOM', code: 'CÓDIGO', archive: 'ARCHIVE', home: 'Inicio', faq: 'FAQ', jewelCode: 'Código Joya' },
    de: { collections: 'KOLLEKTIONEN', showroom: 'SHOWROOM', code: 'CODE', archive: 'ARCHIV', home: 'Startseite', faq: 'FAQ', jewelCode: 'Schmuck-Code' },
    ar: { collections: 'المجموعات', showroom: 'صالة العرض', code: 'الرمز', archive: 'الأرشيف', home: 'الرئيسية', faq: 'FAQ', jewelCode: 'رمز المجوهرات' },
};

const nav = navLabels[currentLang] || navLabels.en;
const langPaths = Object.fromEntries(supportedLangs.map(l => [l, getLanguagePath(l)])) as Record<Lang, string>;
const langLabels: Record<Lang, string> = { en: 'EN', it: 'IT', es: 'ES', de: 'DE', ar: 'AR' };
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 ease-in-out">
    <nav class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex justify-between items-center">
        <!-- Logo -->
        <a href={`/${currentLang}`} class="font-bodoni text-3xl font-bold tracking-wider text-bianco-sporco opacity-0 animate-fade-in-delay">
            PORRATI
        </a>

        <!-- Desktop nav (hidden on mobile) -->
        <div class="hidden md:flex items-center gap-8 text-sm font-medium opacity-0 animate-fade-in-delay">
            <div class="flex items-center gap-6">
                <a href={`/${currentLang}/${routeMap[currentLang].collections}`}
                   class="text-greige-chiaro hover:text-bianco-sporco transition-colors duration-300 uppercase tracking-wide text-xs">
                    {nav.collections}
                </a>
                <a href={`/${currentLang}/${routeMap[currentLang].showroom}`}
                   class="text-greige-chiaro hover:text-bianco-sporco transition-colors duration-300 uppercase tracking-wide text-xs">
                    {nav.showroom}
                </a>
                <a href={`/${currentLang}/${routeMap[currentLang].code}`}
                   class="text-greige-chiaro hover:text-bianco-sporco transition-colors duration-300 uppercase tracking-wide text-xs">
                    {nav.code}
                </a>
                <a href={`/${currentLang}/${routeMap[currentLang].archive}`}
                   class="text-greige-chiaro hover:text-bianco-sporco transition-colors duration-300 uppercase tracking-wide text-xs">
                    {nav.archive}
                </a>
                <div class="w-px h-3 bg-white/20"></div>
            </div>
            <div class="relative lang-dropdown-container">
                <button type="button" class="lang-dropdown-btn flex items-center gap-1 text-bianco-sporco text-xs uppercase tracking-wider">
                    {langLabels[currentLang]}
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <div class="lang-dropdown hidden absolute right-0 top-full mt-2 bg-nero-assoluto/95 backdrop-blur-md border border-grigio-antracite/40 rounded-lg py-1 min-w-[80px] shadow-xl">
                    {supportedLangs.map(l => (
                        <a href={langPaths[l]} class:list={[
                            "block px-4 py-1.5 text-xs uppercase tracking-wider transition-colors duration-200",
                            { "text-bianco-sporco font-bold": l === currentLang, "text-greige-chiaro/70 hover:text-bianco-sporco": l !== currentLang }
                        ]}>{langLabels[l]}</a>
                    ))}
                </div>
            </div>
        </div>

        <!-- Mobile hamburger button -->
        <button id="mobile-menu-btn" type="button" aria-label="Menu" class="md:hidden opacity-0 animate-fade-in-delay text-bianco-sporco p-2 -mr-2">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
    </nav>
</header>

<!-- Mobile menu overlay -->
<div id="mobile-menu" class="mobile-menu-overlay" aria-hidden="true">
    <div class="mobile-menu-panel">
        <div class="flex justify-between items-center px-6 py-6">
            <span class="font-bodoni text-3xl font-bold tracking-wider text-bianco-sporco">PORRATI</span>
            <button id="mobile-menu-close" type="button" aria-label="Chiudi menu" class="text-bianco-sporco p-2 -mr-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <nav class="flex flex-col gap-1 px-6 mt-4">
            <a href={`/${currentLang}`} class="mobile-nav-link">{nav.home}</a>
            <a href={`/${currentLang}/${routeMap[currentLang].collections}`} class="mobile-nav-link">{nav.collections}</a>
            <a href={`/${currentLang}/${routeMap[currentLang].showroom}`} class="mobile-nav-link">{nav.showroom}</a>
            <a href={`/${currentLang}/${routeMap[currentLang].code}`} class="mobile-nav-link">{nav.jewelCode}</a>
            <a href={`/${currentLang}/${routeMap[currentLang].archive}`} class="mobile-nav-link">{nav.archive}</a>
            <a href={`/${currentLang}/${routeMap[currentLang].faq}`} class="mobile-nav-link">{nav.faq}</a>
        </nav>
        <div class="px-6 mt-10 flex flex-wrap items-center gap-3 text-sm">
            {supportedLangs.map((l, i) => (
                <Fragment>
                    {i > 0 && <span class="text-grigio-antracite">/</span>}
                    <a href={langPaths[l]} class:list={[
                        "uppercase tracking-wider transition-colors duration-300",
                        { "text-bianco-sporco font-bold": l === currentLang, "text-greige-chiaro/60": l !== currentLang }
                    ]}>{langLabels[l]}</a>
                </Fragment>
            ))}
        </div>
    </div>
</div>

<script>
    const header = document.getElementById('main-header');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');

    const handleScroll = () => {
        if (window.scrollY > 50) {
            header?.classList.add('scrolled');
        } else {
            header?.classList.remove('scrolled');
        }
    };
    window.addEventListener('scroll', handleScroll, { passive: true });

    function openMenu() {
        mobileMenu?.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        mobileMenu?.setAttribute('aria-hidden', 'false');
    }
    function closeMenu() {
        mobileMenu?.classList.remove('is-open');
        document.body.style.overflow = '';
        mobileMenu?.setAttribute('aria-hidden', 'true');
    }

    menuBtn?.addEventListener('click', openMenu);
    menuClose?.addEventListener('click', closeMenu);
    mobileMenu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));

    // Language dropdown toggle
    const langBtn = document.querySelector('.lang-dropdown-btn');
    const langDropdown = document.querySelector('.lang-dropdown');
    langBtn?.addEventListener('click', () => langDropdown?.classList.toggle('hidden'));
    document.addEventListener('click', (e) => {
        if (!(e.target as Element)?.closest('.lang-dropdown-container')) {
            langDropdown?.classList.add('hidden');
        }
    });
</script>

<style>
    #main-header {
        background: linear-gradient(180deg, rgba(12, 12, 12, 0.5) 0%, transparent 100%);
    }
    #main-header.scrolled {
        background-color: rgba(32, 37, 48, 0.9);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--grigio-antracite);
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-delay {
        animation: fadeIn 1s ease-out 1.5s forwards;
    }

    /* Mobile menu */
    .mobile-menu-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        visibility: hidden;
        opacity: 0;
        transition: opacity 0.35s ease, visibility 0.35s ease;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
    }
    .mobile-menu-overlay.is-open {
        visibility: visible;
        opacity: 1;
    }
    .mobile-menu-panel {
        position: absolute;
        top: 0;
        right: 0;
        width: 85%;
        max-width: 360px;
        height: 100%;
        background: #0C0C0C;
        border-left: 1px solid rgba(75, 79, 81, 0.4);
        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        overflow-y: auto;
    }
    .mobile-menu-overlay.is-open .mobile-menu-panel {
        transform: translateX(0);
    }
    .mobile-nav-link {
        display: block;
        padding: 0.875rem 0;
        font-family: 'Bodoni Moda', serif;
        font-size: 1.25rem;
        color: #D9D9D9;
        letter-spacing: 0.05em;
        border-bottom: 1px solid rgba(75, 79, 81, 0.25);
        transition: color 0.3s ease;
    }
    .mobile-nav-link:hover {
        color: #fff;
    }
</style>