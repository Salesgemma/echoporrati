---
// src/components/Header.astro
const currentPath = Astro.url.pathname;
const isItalian = currentPath.startsWith('/it');
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 ease-in-out">
    <nav class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex justify-between items-center">
        <!-- Logo -->
        <a href={isItalian ? '/it' : '/en'} class="font-bodoni text-3xl font-bold tracking-wider text-bianco-sporco opacity-0 animate-fade-in-delay">
            PORRATI
        </a>

        <!-- Desktop nav (hidden on mobile) -->
        <div class="hidden md:flex items-center gap-8 text-sm font-medium opacity-0 animate-fade-in-delay">
            <div class="flex items-center gap-6">
                <a href={isItalian ? '/it/collezioni' : '/en/collections'} 
                   class="text-greige-chiaro hover:text-bianco-sporco transition-colors duration-300 uppercase tracking-wide text-xs">
                    {isItalian ? 'COLLEZIONI' : 'COLLECTIONS'}
                </a>
                <a href={isItalian ? '/it/showroom-milano' : '/en/showroom-milan'} 
                   class="text-greige-chiaro hover:text-bianco-sporco transition-colors duration-300 uppercase tracking-wide text-xs">
                    SHOWROOM
                </a>
                <a href={isItalian ? '/it/codice-gioiello' : '/en/jewel-code'} 
                   class="text-greige-chiaro hover:text-bianco-sporco transition-colors duration-300 uppercase tracking-wide text-xs">
                    {isItalian ? 'CODICE' : 'CODE'}
                </a>
                <a href={isItalian ? '/it/borgonuovo10-archive' : '/en/borgonuovo10-archive'} 
                   class="text-greige-chiaro hover:text-bianco-sporco transition-colors duration-300 uppercase tracking-wide text-xs">
                    ARCHIVE
                </a>
                <div class="w-px h-3 bg-white/20"></div>
            </div>
            <div class="flex items-center gap-4">
                <a href="/it" class:list={[
                    "hover:text-bianco-sporco transition-colors duration-300",
                    { "text-bianco-sporco": isItalian, "text-greige-chiaro": !isItalian }
                ]}>IT</a>
                <span class="text-grigio-antracite">/</span>
                <a href="/en" class:list={[
                    "hover:text-bianco-sporco transition-colors duration-300",
                    { "text-bianco-sporco": !isItalian, "text-greige-chiaro": isItalian }
                ]}>EN</a>
            </div>
        </div>

        <!-- Mobile hamburger button -->
        <button id="mobile-menu-btn" type="button" aria-label="Menu" class="md:hidden opacity-0 animate-fade-in-delay text-bianco-sporco p-2 -mr-2">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
    </nav>
</header>

<!-- Mobile menu overlay -->
<div id="mobile-menu" class="mobile-menu-overlay" aria-hidden="true">
    <div class="mobile-menu-panel">
        <div class="flex justify-between items-center px-6 py-6">
            <span class="font-bodoni text-3xl font-bold tracking-wider text-bianco-sporco">PORRATI</span>
            <button id="mobile-menu-close" type="button" aria-label="Chiudi menu" class="text-bianco-sporco p-2 -mr-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <nav class="flex flex-col gap-1 px-6 mt-4">
            <a href={isItalian ? '/it' : '/en'} class="mobile-nav-link">{isItalian ? 'Home' : 'Home'}</a>
            <a href={isItalian ? '/it/collezioni' : '/en/collections'} class="mobile-nav-link">{isItalian ? 'Collezioni' : 'Collections'}</a>
            <a href={isItalian ? '/it/showroom-milano' : '/en/showroom-milan'} class="mobile-nav-link">Showroom</a>
            <a href={isItalian ? '/it/codice-gioiello' : '/en/jewel-code'} class="mobile-nav-link">{isItalian ? 'Codice Gioiello' : 'Jewel Code'}</a>
            <a href={isItalian ? '/it/borgonuovo10-archive' : '/en/borgonuovo10-archive'} class="mobile-nav-link">Archive</a>
            <a href={isItalian ? '/it/faq' : '/en/faq'} class="mobile-nav-link">FAQ</a>
        </nav>
        <div class="px-6 mt-10 flex items-center gap-6 text-sm">
            <a href="/it" class:list={[
                "uppercase tracking-wider transition-colors duration-300",
                { "text-bianco-sporco font-bold": isItalian, "text-greige-chiaro/60": !isItalian }
            ]}>IT</a>
            <span class="text-grigio-antracite">/</span>
            <a href="/en" class:list={[
                "uppercase tracking-wider transition-colors duration-300",
                { "text-bianco-sporco font-bold": !isItalian, "text-greige-chiaro/60": isItalian }
            ]}>EN</a>
        </div>
    </div>
</div>

<script>
    const header = document.getElementById('main-header');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');

    const handleScroll = () => {
        if (window.scrollY > 50) {
            header?.classList.add('scrolled');
        } else {
            header?.classList.remove('scrolled');
        }
    };
    window.addEventListener('scroll', handleScroll, { passive: true });

    function openMenu() {
        mobileMenu?.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        mobileMenu?.setAttribute('aria-hidden', 'false');
    }
    function closeMenu() {
        mobileMenu?.classList.remove('is-open');
        document.body.style.overflow = '';
        mobileMenu?.setAttribute('aria-hidden', 'true');
    }

    menuBtn?.addEventListener('click', openMenu);
    menuClose?.addEventListener('click', closeMenu);
    mobileMenu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
</script>

<style>
    #main-header {
        background: linear-gradient(180deg, rgba(12, 12, 12, 0.5) 0%, transparent 100%);
    }
    #main-header.scrolled {
        background-color: rgba(32, 37, 48, 0.9);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--grigio-antracite);
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-delay {
        animation: fadeIn 1s ease-out 1.5s forwards;
    }

    /* Mobile menu */
    .mobile-menu-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        visibility: hidden;
        opacity: 0;
        transition: opacity 0.35s ease, visibility 0.35s ease;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
    }
    .mobile-menu-overlay.is-open {
        visibility: visible;
        opacity: 1;
    }
    .mobile-menu-panel {
        position: absolute;
        top: 0;
        right: 0;
        width: 85%;
        max-width: 360px;
        height: 100%;
        background: #0C0C0C;
        border-left: 1px solid rgba(75, 79, 81, 0.4);
        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        overflow-y: auto;
    }
    .mobile-menu-overlay.is-open .mobile-menu-panel {
        transform: translateX(0);
    }
    .mobile-nav-link {
        display: block;
        padding: 0.875rem 0;
        font-family: 'Bodoni Moda', serif;
        font-size: 1.25rem;
        color: #D9D9D9;
        letter-spacing: 0.05em;
        border-bottom: 1px solid rgba(75, 79, 81, 0.25);
        transition: color 0.3s ease;
    }
    .mobile-nav-link:hover {
        color: #fff;
    }
</style>