---
// src/components/FeaturedCollections.astro
---
<!-- Featured Collections Section - The "What" -->
<section class="py-24 md:py-32 bg-blu-inchiostro">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="font-serif text-4xl md:text-5xl font-bold text-bianco-sporco mb-4">
                Iconic Collections
            </h2>
            <p class="text-lg text-greige-chiaro max-w-2xl mx-auto">
                Discover the essence of architectural jewelry through our most emblematic pieces.
            </p>
        </div>
        
        <!-- Collection Blocks -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Collection 1 -->
            <div class="group relative overflow-hidden rounded-lg bg-grigio-blu-notte h-96 cursor-pointer">
                <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-all duration-500"></div>
                <div class="absolute bottom-8 left-8 right-8">
                    <h3 class="font-serif text-2xl font-bold text-bianco-sporco mb-2">TERRA Collection</h3>
                    <p class="text-greige-chiaro mb-4">Earthy foundations, architectural precision</p>
                    <button class="bg-bianco-sporco text-nero-assoluto px-6 py-2 text-sm font-medium hover:bg-greige-chiaro transition-colors">
                        Scopri
                    </button>
                </div>
                <!-- Placeholder for collection image/video -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-greige-chiaro text-sm">Collection Image/Video</span>
                </div>
            </div>
            
            <!-- Collection 2 -->
            <div class="group relative overflow-hidden rounded-lg bg-grigio-blu-notte h-96 cursor-pointer">
                <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-all duration-500"></div>
                <div class="absolute bottom-8 left-8 right-8">
                    <h3 class="font-serif text-2xl font-bold text-bianco-sporco mb-2">ECHO Collection</h3>
                    <p class="text-greige-chiaro mb-4">Resonant forms, timeless geometry</p>
                    <button class="bg-bianco-sporco text-nero-assoluto px-6 py-2 text-sm font-medium hover:bg-greige-chiaro transition-colors">
                        Scopri
                    </button>
                </div>
                <!-- Placeholder for collection image/video -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-greige-chiaro text-sm">Collection Image/Video</span>
                </div>
            </div>
            
            <!-- Collection 3 -->
            <div class="group relative overflow-hidden rounded-lg bg-grigio-blu-notte h-96 cursor-pointer md:col-span-2 lg:col-span-1">
                <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-all duration-500"></div>
                <div class="absolute bottom-8 left-8 right-8">
                    <h3 class="font-serif text-2xl font-bold text-bianco-sporco mb-2">FORMA Collection</h3>
                    <p class="text-greige-chiaro mb-4">Pure essence, intellectual design</p>
                    <button class="bg-bianco-sporco text-nero-assoluto px-6 py-2 text-sm font-medium hover:bg-greige-chiaro transition-colors">
                        Scopri
                    </button>
                </div>
                <!-- Placeholder for collection image/video -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-greige-chiaro text-sm">Collection Image/Video</span>
                </div>
            </div>
        </div>
    </div>
</section>