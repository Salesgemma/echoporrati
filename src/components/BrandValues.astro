---
// src/components/BrandValues.astro
---
<!-- Brand Values Section - The "How" -->
<section class="py-24 md:py-32 bg-grigio-blu-notte">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="font-serif text-4xl md:text-5xl font-bold text-bianco-sporco mb-4">
                Our Foundation
            </h2>
            <p class="text-lg text-greige-chiaro max-w-2xl mx-auto">
                Three immutable principles that guide every creation.
            </p>
        </div>
        
        <!-- Values Carousel -->
        <div class="overflow-x-auto">
            <div class="flex space-x-8 pb-4" style="width: max-content;">
                <!-- Value 1: Rigor -->
                <div class="flex-none w-80 bg-nero-assoluto rounded-lg p-8">
                    <div class="h-48 bg-grigio-antracite rounded-lg mb-6 flex items-center justify-center">
                        <span class="text-greige-chiaro text-sm">Architectural Image</span>
                    </div>
                    <h3 class="font-serif text-2xl font-bold text-bianco-sporco mb-4">Rigor</h3>
                    <p class="text-greige-chiaro leading-relaxed">
                        Precision in every line, discipline in every choice. 
                        Architecture demands exactitude, and so do we.
                    </p>
                </div>
                
                <!-- Value 2: Intellect -->
                <div class="flex-none w-80 bg-nero-assoluto rounded-lg p-8">
                    <div class="h-48 bg-grigio-antracite rounded-lg mb-6 flex items-center justify-center">
                        <span class="text-greige-chiaro text-sm">Abstract Design Image</span>
                    </div>
                    <h3 class="font-serif text-2xl font-bold text-bianco-sporco mb-4">Intellect</h3>
                    <p class="text-greige-chiaro leading-relaxed">
                        Each piece embodies a thought, a philosophical statement 
                        that transcends mere decoration.
                    </p>
                </div>
                
                <!-- Value 3: Permanence -->
                <div class="flex-none w-80 bg-nero-assoluto rounded-lg p-8">
                    <div class="h-48 bg-grigio-antracite rounded-lg mb-6 flex items-center justify-center">
                        <span class="text-greige-chiaro text-sm">Timeless Structure Image</span>
                    </div>
                    <h3 class="font-serif text-2xl font-bold text-bianco-sporco mb-4">Permanence</h3>
                    <p class="text-greige-chiaro leading-relaxed">
                        Designed to endure beyond trends, beyond time. 
                        Creating heirlooms for future generations.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>