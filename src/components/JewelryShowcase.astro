---
// src/components/JewelryShowcase.astro
interface Props {
    title: string;
    subtitle: string;
    buttonText: string;

    // Le props per i nomi delle categorie sono ora opzionali
    cat1Name?: string;
    cat2Name?: string;
    cat3Name?: string;
    cat4Name?: string;
}
const { 
    title, 
    subtitle, 
    buttonText,
    cat1Name = "Pendant",
    cat2Name = "Ring",
    cat3Name = "Bracelet",
    cat4Name = "Earring"
} = Astro.props;

// Map category names to collection paths
const getCategoryPath = (categoryName: string, currentPath: string) => {
    // Determine if we're on an English or Italian page
    const isEnglish = currentPath.startsWith('/en/') || currentPath === '/en';
    
    // Map category names to collection paths for each language
    if (isEnglish) {
        switch (categoryName) {
            case cat1Name: return '/en/collections/pendants';
            case cat2Name: return '/en/collections/rings';
            case cat3Name: return '/en/collections/bracelets';
            case cat4Name: return '/en/collections/earrings';
            default: return '#';
        }
    } else {
        // Italian mappings
        switch (categoryName) {
            case cat1Name: return '/it/collezioni/pendenti';
            case cat2Name: return '/it/collezioni/anelli';
            case cat3Name: return '/it/collezioni/bracciali';
            case cat4Name: return '/it/collezioni/orecchini';
            default: return '#';
        }
    }
};

const categories = [
    { name: cat1Name, video: '/videos-optimized/pendants/axioma.mp4', poster: '/photos/pendants/axioma.jpg', alt: `${cat1Name}` },
    { name: cat2Name, video: '/videos-optimized/rings/solitario-essenziale.mp4', poster: '/photos/rings/solitario-essenziale.jpg', alt: `${cat2Name}` },
    { name: cat3Name, video: '/videos-optimized/bracelets/linea-pura-01.mp4', poster: '/photos/bracelets/linea-pura-01.jpg', alt: `${cat3Name}` },
    { name: cat4Name, video: '/videos-optimized/earrings/sequenza-geometrica-06.mp4', poster: '/photos/earrings/sequenza-geometrica-06.jpg', alt: `${cat4Name}` }
];
---
<section class="py-24 md:py-32 bg-nero-assoluto">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="font-serif text-4xl md:text-5xl font-bold text-bianco-sporco mb-4">
                {title}
            </h2>
            <p class="text-lg text-greige-chiaro max-w-2xl mx-auto leading-relaxed">
                <Fragment set:html={subtitle} />
            </p>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
            {categories.map(category => (
                <a href={getCategoryPath(category.name, Astro.url.pathname)} class="showcase-card group block">
                    <div class="aspect-square bg-nero-assoluto rounded-xl overflow-hidden">
                        <video 
                            src={category.video}
                            poster={category.poster}
                            aria-label={category.alt}
                            class="showcase-video w-full h-full object-contain transition-transform duration-700 ease-out group-hover:scale-110"
                            loop
                            muted
                            playsinline
                            preload="none"
                        ></video>
                    </div>
                    <div class="mt-4 text-center">
                        <h3 class="font-serif text-lg md:text-xl text-bianco-sporco mb-2">{category.name}</h3>
                        <span class="text-greige-chiaro/60 text-xs uppercase tracking-widest group-hover:text-bianco-sporco transition-colors duration-300">
                            {buttonText} →
                        </span>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<script>
    const showcaseVideos = document.querySelectorAll('.showcase-video');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            const video = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) {
                video.play().catch(() => {});
            } else {
                video.pause();
            }
        });
    }, { threshold: 0.3 });
    showcaseVideos.forEach(v => observer.observe(v));
</script>