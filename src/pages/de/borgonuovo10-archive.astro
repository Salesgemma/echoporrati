	<main class="bg-nero-assoluto py-24 md:py-32">
		<div class="max-w-3xl mx-auto px-6 text-center">
			<h1 class="font-bodoni text-4xl md:text-5xl text-bianco-sporco mb-4">Borgonuovo-10 Archiv</h1>
			<p class="text-greige-chiaro text-lg mb-10">Antrag auf privaten Zugang zum Kollektionsarchiv.</p>
			<Borgonuovo10ArchiveForm client:load lang="de" />
		</div>
	</main>
</Layout>
