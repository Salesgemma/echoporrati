---
import Layout from '../../layouts/Layout.astro';
import JewelCodeSearch from '../../components/react/JewelCodeSearch.tsx';
---
<Layout title="Busca tu Joya | PORRATI" lang="es">
	<main class="bg-nero-assoluto py-24 md:py-32">
		<div class="max-w-7xl mx-auto px-6">
			<div class="text-center mb-12">
				<h1 class="font-bodoni text-4xl md:text-5xl text-bianco-sporco mb-4">Busca tu Joya</h1>
				<p class="text-greige-chiaro text-lg max-w-2xl mx-auto">Introduce el código de tu joya PORRATI para verificar autenticidad y ver los detalles del producto.</p>
			</div>
			<JewelCodeSearch client:load lang="es" />
		</div>
	</main>
</Layout>
