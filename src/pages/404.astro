---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found | PORRATI" lang="en" metaRobots="noindex, nofollow">
  <main class="min-h-screen flex items-center justify-center bg-nero-assoluto">
    <div class="text-center px-6">
      <h1 class="text-5xl font-serif text-bianco-sporco mb-4">404</h1>
      <p class="text-greige-chiaro mb-8">The page you are looking for does not exist.</p>
      <a class="text-blue-300 hover:text-blue-100 underline" href="/en">Go back to Home</a>
    </div>
  </main>
</Layout>
