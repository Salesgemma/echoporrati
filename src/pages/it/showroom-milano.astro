---
import Layout from '../../layouts/Layout.astro';
import SeoSchema from '../../components/SeoSchema.astro';

const metaTitle = 'Showroom Milano | PORRATI';
const metaDescription = 'Visita il Borgonuovo-10 Jewel Showroom a Milano e scopri da vicino le creazioni PORRATI con diamanti lab-grown.';

const showroomSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.porratigioielli.it/it"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Showroom Milano",
          "item": "https://www.porratigioielli.it/it/showroom-milano"
        }
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://www.porratigioielli.it/#showroom"
    }
  ]
};
---

<Layout title={metaTitle} lang="it" metaTitle={metaTitle} metaDescription={metaDescription}>
  <Fragment slot="head">
    <SeoSchema schema={showroomSchema} />
  </Fragment>

  <main class="bg-nero-assoluto py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6">
      <h1 class="font-bodoni text-4xl md:text-5xl text-bianco-sporco mb-6">Showroom Milano</h1>
      <p class="text-greige-chiaro text-lg mb-10">
        Il Borgonuovo-10 Jewel Showroom è lo spazio fisico dove poter vedere e provare le creazioni PORRATI a Milano.
      </p>

      <div class="grid md:grid-cols-2 gap-10 mb-16">
        <section>
          <h2 class="font-bodoni text-2xl text-bianco-sporco mb-4">Indirizzo</h2>
          <p class="text-greige-chiaro">
            Via Borgonuovo, 10<br />
            20121 Milano MI, Italia
          </p>
          <div class="mt-4 space-y-2">
            <p class="text-greige-chiaro">
              Telefono:
              <a href="tel:+390223185211" class="underline hover:text-bianco-sporco"> +39 02 2318 5211</a>
            </p>
            <p class="text-greige-chiaro">
              Orari indicativi: lunedì – sabato, 10:00 – 19:00. Si consiglia appuntamento.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="https://www.google.com/maps/search/?api=1&query=Via+Borgonuovo,+10,+20121+Milano+MI,+Italy"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-4 py-2 rounded-full bg-bianco-sporco text-nero-assoluto text-sm font-medium"
            >
              Apri in Google Maps
            </a>
            <a
              href="tel:+390223185211"
              class="inline-flex items-center px-4 py-2 rounded-full border border-bianco-sporco text-bianco-sporco text-sm font-medium"
            >
              Chiama lo showroom
            </a>
          </div>
        </section>

        <section>
          <h2 class="font-bodoni text-2xl text-bianco-sporco mb-4">Esperienza in showroom</h2>
          <p class="text-greige-chiaro mb-3">
            In showroom è possibile vedere da vicino i volumi, le proporzioni e la luce dei diamanti lab-grown PORRATI.
          </p>
          <p class="text-greige-chiaro mb-3">
            Lo spazio è pensato come un atelier architettonico: ogni pezzo viene presentato con attenzione alla composizione e alla luce.
          </p>
          <p class="text-greige-chiaro">
            È possibile richiedere consulenze dedicate per anelli di fidanzamento, pezzi unici e collezioni su misura.
          </p>
        </section>
      </div>
    </div>
  </main>
</Layout>
