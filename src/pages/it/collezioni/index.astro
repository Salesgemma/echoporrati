---
import Layout from '../../../layouts/Layout.astro';
import SeoSchema from '../../../components/SeoSchema.astro';

const categories = [
  { slug: 'pendenti', name: 'Pendenti', description: 'Esplora pendenti architettonici con diamanti lab‑grown.' },
  { slug: 'anelli', name: 'Anelli', description: 'Anelli di fidanzamento e di design, creati a Milano.' },
  { slug: 'bracciali', name: 'Bracciali', description: 'Tennis e bracciali architettonici.' },
  { slug: 'orecchini', name: 'Orecchini', description: 'Orecchini geometrici e a cascata.' }
];

const metaTitle = 'Collezioni | PORRATI Milano';
const metaDescription = 'Scopri le collezioni PORRATI: anelli, pendenti, bracciali e orecchini con diamanti lab‑grown a Milano.';

const itemListSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ItemList",
      "itemListElement": categories.map((c, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Collection",
          "name": c.name,
          "url": `https://www.porratigioielli.it/it/collezioni/${c.slug}`
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.porratigioielli.it/it"},
        {"@type": "ListItem", "position": 2, "name": "Collezioni", "item": "https://www.porratigioielli.it/it/collezioni"}
      ]
    }
  ]
};
---
<Layout title="PORRATI | Collezioni" lang="it" metaTitle={metaTitle} metaDescription={metaDescription}>
  <Fragment slot="head">
    <SeoSchema schema={itemListSchema} />
  </Fragment>
  <main class="py-24 md:py-32 bg-nero-assoluto">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="font-bodoni text-5xl text-bianco-sporco">Collezioni</h1>
        <p class="mt-4 text-greige-chiaro">Esplora le nostre categorie.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {categories.map(c => (
          <a href={`/it/collezioni/${c.slug}`} class="block group border border-grigio-antracite rounded-xl p-6 hover:border-blue-400/50 transition-colors">
            <h2 class="text-xl font-serif text-bianco-sporco mb-2">{c.name}</h2>
            <p class="text-greige-chiaro text-sm">{c.description}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
