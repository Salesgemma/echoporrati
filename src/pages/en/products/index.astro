---
import Layout from '../../../layouts/Layout.astro';
import SeoSchema from '../../../components/SeoSchema.astro';
import allProducts from '../../../data/products.json';

const productsData = allProducts.en;
const products = Object.entries(productsData).map(([id, data]) => ({ id, ...data }));

const metaTitle = 'Products | PORRATI Milan';
const metaDescription = 'Browse PORRATI products: architectural jewelry with lab‑grown diamonds in Milan.';

const itemListSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ItemList",
      "itemListElement": products.map((p, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Product",
          "name": p.title,
          "url": `https://www.porratigioielli.it/en/products/${p.id}`
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.porratigioielli.it/en"},
        {"@type": "ListItem", "position": 2, "name": "Products", "item": "https://www.porratigioielli.it/en/products"}
      ]
    }
  ]
};
---
<Layout title="PORRATI | Products" lang="en" metaTitle={metaTitle} metaDescription={metaDescription}>
  <Fragment slot="head">
    <SeoSchema schema={itemListSchema} />
  </Fragment>
  <main class="py-24 md:py-32 bg-nero-assoluto">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="font-bodoni text-5xl text-bianco-sporco">Products</h1>
        <p class="mt-4 text-greige-chiaro">All creations.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {products.map(p => (
          <a href={`/en/products/${p.id}`} class="block group border border-grigio-antracite rounded-xl p-6 hover:border-blue-400/50 transition-colors">
            <h2 class="text-lg font-serif text-bianco-sporco mb-2">{p.title}</h2>
            <p class="text-greige-chiaro text-sm line-clamp-3">{p.description}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
