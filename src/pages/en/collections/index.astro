---
import Layout from '../../../layouts/Layout.astro';
import SeoSchema from '../../../components/SeoSchema.astro';

const categories = [
  { slug: 'pendants', name: 'Pendants', description: 'Explore architectural pendants with lab‑grown diamonds.' },
  { slug: 'rings', name: 'Rings', description: 'Engagement and design rings crafted in Milan.' },
  { slug: 'bracelets', name: 'Bracelets', description: 'Tennis and architectural bracelets.' },
  { slug: 'earrings', name: 'Earrings', description: 'Geometric and cascading earrings.' }
];

const metaTitle = 'Collections | PORRATI Milan';
const metaDescription = 'Discover PORRATI collections: rings, pendants, bracelets and earrings with lab‑grown diamonds in Milan.';

const itemListSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ItemList",
      "itemListElement": categories.map((c, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Collection",
          "name": c.name,
          "url": `https://www.porratigioielli.it/en/collections/${c.slug}`
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.porratigioielli.it/en"},
        {"@type": "ListItem", "position": 2, "name": "Collections", "item": "https://www.porratigioielli.it/en/collections"}
      ]
    }
  ]
};
---
<Layout title="PORRATI | Collections" lang="en" metaTitle={metaTitle} metaDescription={metaDescription}>
  <Fragment slot="head">
    <SeoSchema schema={itemListSchema} />
  </Fragment>
  <main class="py-24 md:py-32 bg-nero-assoluto">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="font-bodoni text-5xl text-bianco-sporco">Collections</h1>
        <p class="mt-4 text-greige-chiaro">Explore our categories.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {categories.map(c => (
          <a href={`/en/collections/${c.slug}`} class="block group border border-grigio-antracite rounded-xl p-6 hover:border-blue-400/50 transition-colors">
            <h2 class="text-xl font-serif text-bianco-sporco mb-2">{c.name}</h2>
            <p class="text-greige-chiaro text-sm">{c.description}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
