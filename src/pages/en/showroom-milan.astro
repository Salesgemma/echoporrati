---
import Layout from '../../layouts/Layout.astro';
import SeoSchema from '../../components/SeoSchema.astro';

const metaTitle = 'Showroom Milan | PORRATI';
const metaDescription = 'Visit the Borgonuovo-10 Jewel Showroom in Milan and experience PORRATI creations with lab-grown diamonds in person.';

const showroomSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.porratigioielli.it/en"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Showroom Milan",
          "item": "https://www.porratigioielli.it/en/showroom-milan"
        }
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://www.porratigioielli.it/#showroom"
    }
  ]
};
---

<Layout title={metaTitle} lang="en" metaTitle={metaTitle} metaDescription={metaDescription}>
  <Fragment slot="head">
    <SeoSchema schema={showroomSchema} />
  </Fragment>

  <main class="bg-nero-assoluto py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6">
      <h1 class="font-bodoni text-4xl md:text-5xl text-bianco-sporco mb-6">Showroom Milan</h1>
      <p class="text-greige-chiaro text-lg mb-10">
        The Borgonuovo-10 Jewel Showroom is the physical space where you can discover and try PORRATI creations in Milan.
      </p>

      <div class="grid md:grid-cols-2 gap-10 mb-16">
        <section>
          <h2 class="font-bodoni text-2xl text-bianco-sporco mb-4">Address</h2>
          <p class="text-greige-chiaro">
            Via Borgonuovo, 10<br />
            20121 Milan MI, Italy
          </p>
          <div class="mt-4 space-y-2">
            <p class="text-greige-chiaro">
              Phone:
              <a href="tel:+390223185211" class="underline hover:text-bianco-sporco"> +39 02 2318 5211</a>
            </p>
            <p class="text-greige-chiaro">
              Indicative hours: Monday – Saturday, 10:00 – 19:00. Visit by appointment is recommended.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="https://www.google.com/maps/search/?api=1&query=Via+Borgonuovo,+10,+20121+Milano+MI,+Italy"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-4 py-2 rounded-full bg-bianco-sporco text-nero-assoluto text-sm font-medium"
            >
              Open in Google Maps
            </a>
            <a
              href="tel:+390223185211"
              class="inline-flex items-center px-4 py-2 rounded-full border border-bianco-sporco text-bianco-sporco text-sm font-medium"
            >
              Call the showroom
            </a>
          </div>
        </section>

        <section>
          <h2 class="font-bodoni text-2xl text-bianco-sporco mb-4">Showroom experience</h2>
          <p class="text-greige-chiaro mb-3">
            In the showroom, you can perceive volumes, proportions and the light of PORRATI lab-grown diamonds in real scale.
          </p>
          <p class="text-greige-chiaro mb-3">
            The space is conceived as an architectural atelier: each piece is presented with careful attention to composition and light.
          </p>
          <p class="text-greige-chiaro">
            You can request dedicated consultations for engagement rings, unique pieces and curated collections.
          </p>
        </section>
      </div>
    </div>
  </main>
</Layout>
