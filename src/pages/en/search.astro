---
import Layout from '../../layouts/Layout.astro';

const q = Astro.url.searchParams.get('q') || '';
---
<Layout title="Search | PORRATI" lang="en" metaRobots="noindex, nofollow">
  <main class="min-h-screen bg-nero-assoluto py-24">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="font-bodoni text-4xl text-bianco-sporco mb-6">Search</h1>
      <form method="get" class="flex gap-3 mb-8">
        <label for="search-q" class="sr-only">Search query</label>
        <input id="search-q" type="text" name="q" value={q} placeholder="Search products or topics…" class="flex-1 px-4 py-3 rounded-lg bg-grigio-blu-notte text-bianco-sporco border border-grigio-antracite outline-none" />
        <button class="px-5 py-3 rounded-lg bg-bianco-sporco text-nero-assoluto font-medium">Search</button>
      </form>
      {q ? (
        <p class="text-greige-chiaro">Search for: <strong class="text-bianco-sporco">{q}</strong> — results coming soon.</p>
      ) : (
        <p class="text-greige-chiaro">Type a query to search.</p>
      )}
    </div>
  </main>
</Layout>
